# ─────────────────────────────────────────────
# GOOGLE GEMINI API KEYS
#
# WHY THREE KEYS:
#   This project runs on Gemini free-tier keys, which enforce a
#   per-minute request quota (RPM limit). A single investigation
#   triggers 6-10 LLM calls across reasoning loops, which exhausts
#   the free-tier RPM limit mid-investigation and causes 429 errors.
#
#   Rotating across 3 separate free-tier keys triples the available
#   RPM budget and keeps investigations running without interruption.
#
# IN PRODUCTION THIS WOULD NOT BE NEEDED:
#   A paid Gemini API key has a much higher (or configurable) RPM limit,
#   so a single key handles the full investigation load comfortably.
#   The correct production pattern is one key + exponential backoff
#   on 429 responses. Key rotation is purely a free-tier workaround.
#
# SETUP:
#   Create up to 3 free Gemini API keys at https://aistudio.google.com
#   and paste them below. If you only have one key, set all three to
#   the same value — rotation will still work, just without the benefit.
# ─────────────────────────────────────────────

GOOGLE_API_KEY_1=your_gemini_key_1_here
GOOGLE_API_KEY_2=your_gemini_key_2_here
GOOGLE_API_KEY_3=your_gemini_key_3_here

# Fallback — used if none of the above are set
GOOGLE_API_KEY=your_gemini_key_here
